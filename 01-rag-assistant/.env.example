# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Models ────────────────────────────────────────────────────────────────────
# text-embedding-3-small is the default; use text-embedding-3-large for higher
# quality at ~6x the cost.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o-mini

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# ── Chunking (token-based, not character-based) ───────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Generation ────────────────────────────────────────────────────────────────
MAX_TOKENS=1024
TEMPERATURE=0.1

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=RAG Assistant
APP_VERSION=2.0.0
DEBUG=false
LOG_LEVEL=INFO
